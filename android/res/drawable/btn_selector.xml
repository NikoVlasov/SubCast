<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused AND selected (active quality button while D-pad is on it) -->
    <item android:state_focused="true" android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#3b82f6" />
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="#93c5fd" />
        </shape>
    </item>

    <!-- Focused (D-pad cursor on this button) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1d4ed8" />
            <corners android:radius="8dp" />
            <stroke android:width="2dp" android:color="#3b82f6" />
        </shape>
    </item>

    <!-- Selected but not focused (active quality, cursor elsewhere) -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#2563eb" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1e3a8a" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1a1a1a" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#2a2a2a" />
        </shape>
    </item>

</selector>
