<?xml version="1.0" encoding="utf-8"?>
<!-- Fades from opaque black at the top edge to transparent downward,
     so controls are readable over any stream content. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#CC000000"
        android:endColor="#00000000" />
</shape>
