<?xml version="1.0" encoding="utf-8"?>
<!-- Fades from transparent at the top edge to opaque black at the bottom,
     so subtitles are always legible over any stream content. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#CC000000"
        android:endColor="#00000000" />
</shape>
