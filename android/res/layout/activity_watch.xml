<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Stream player – fills the whole screen, never receives D-pad focus ── -->
    <WebView
        android:id="@+id/streamWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <!-- ══════════════════════════════════════════════════════════════════════
         TOP BAR  —  quality selector  +  Twitch login
         Overlaid on the stream; gradient background keeps it readable.
    ═══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/controls_bg_top">

        <!-- Quality: 480p -->
        <TextView
            android:id="@+id/btn480p"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="480p"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/btn_text_color"
            android:background="@drawable/btn_selector"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:focusedByDefault="true"
            android:nextFocusRight="@id/btn720p"
            android:nextFocusDown="@id/btnDelayMinus" />

        <Space android:layout_width="8dp" android:layout_height="1dp" />

        <!-- Quality: 720p -->
        <TextView
            android:id="@+id/btn720p"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="720p"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/btn_text_color"
            android:background="@drawable/btn_selector"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/btn480p"
            android:nextFocusRight="@id/btnAuto"
            android:nextFocusDown="@id/btnDelayMinus" />

        <Space android:layout_width="8dp" android:layout_height="1dp" />

        <!-- Quality: Auto -->
        <TextView
            android:id="@+id/btnAuto"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Auto"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/btn_text_color"
            android:background="@drawable/btn_selector"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/btn720p"
            android:nextFocusRight="@id/btnLogin"
            android:nextFocusDown="@id/btnDelayPlus" />

        <!-- Spacer pushes login to the right -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Login with Twitch -->
        <TextView
            android:id="@+id/btnLogin"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="🟣  Login with Twitch"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="@drawable/btn_twitch_selector"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/btnAuto"
            android:nextFocusDown="@id/btnDelayPlus" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════════
         BOTTOM BAR  —  subtitles  +  delay controls
         Anchored to the bottom; gradient keeps text readable.
    ═══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp"
        android:paddingTop="40dp"
        android:background="@drawable/controls_bg_bottom">

        <!-- Translated subtitle text -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="26sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2"
            android:focusable="false" />

        <!-- Original text + delay controls on the same row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvOriginal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textSize="13sp"
                android:textColor="#555555"
                android:textStyle="italic"
                android:focusable="false" />

            <!-- Delay: minus -->
            <TextView
                android:id="@+id/btnDelayMinus"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="- 1s"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/btn_text_color"
                android:background="@drawable/btn_selector"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusRight="@id/btnDelayPlus"
                android:nextFocusUp="@id/btn480p" />

            <!-- Current delay value (display only) -->
            <TextView
                android:id="@+id/tvDelay"
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:text="Delay: 3s"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#555555"
                android:focusable="false" />

            <!-- Delay: plus -->
            <TextView
                android:id="@+id/btnDelayPlus"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="+ 1s"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/btn_text_color"
                android:background="@drawable/btn_selector"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@id/btnDelayMinus"
                android:nextFocusUp="@id/btnLogin" />

        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
